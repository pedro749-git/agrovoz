{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*.pem)",
      "Read(*.key)",
      "Read(*.p12)",
      "Read(*.pfx)",
      "Read(*.secret)",
      "Bash(cat .env*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat *.p12)",
      "Bash(cat *.pfx)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(grep * .env*)"
    ]
  }
}
