# Supply-chain hardening (audit 2026-07-13)
# Block preinstall/install/postinstall scripts from dependencies.
# Verified: no package in this tree declares lifecycle scripts, so nothing breaks.
ignore-scripts=true

# Refuse packages published less than 7 days ago (mitigates fresh hijacked releases).
# npm reads this in DAYS (pnpm uses minutes): 10080 here meant "before 1998" and
# blocked every install with ENOVERSIONS.
min-release-age=7
