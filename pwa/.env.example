# PWA environment — copy to .env.local and fill in (real values stay out of git).
# Vite inlines every VITE_* variable into the browser bundle at build time, so
# ONLY put public values here. Never the Supabase secret key.

# Supabase project — browser auth client.
VITE_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (sb_publishable_...): the new public client key that replaces
# the legacy anon key. Safe to ship; it only grants what Auth + RLS allow.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Hackathon signup
VITE_HACKATHON_SIGNUP=
VITE_TURNSTILE_SITE_KEY=
